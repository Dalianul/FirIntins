# Medusa — Headless Commerce API
NEXT_PUBLIC_MEDUSA_BACKEND_URL=http://localhost:9000
NEXT_PUBLIC_MEDUSA_PUBLISHABLE_KEY=<from Medusa admin>

# Stripe Payments
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...

# Payload CMS — separate PostgreSQL database from Medusa
# Run: createdb firintins_cms  (or use the same Postgres instance)
PAYLOAD_DATABASE_URL=postgresql://user:pass@localhost:5432/firintins_cms
# Generate: openssl rand -hex 32
PAYLOAD_SECRET=change_me_generate_32_char_random_string
